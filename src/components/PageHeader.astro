---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<header class="mb-12 border-b border-rule pb-10">
  {eyebrow && <p class="mb-4 text-sm text-muted">{eyebrow}</p>}
  <h1 class="max-w-4xl text-4xl font-normal leading-tight tracking-normal text-ink sm:text-5xl">
    {title}
  </h1>
  {
    description && (
      <p class="mt-6 max-w-3xl text-lg leading-8 text-muted">
        {description}
      </p>
    )
  }
</header>
