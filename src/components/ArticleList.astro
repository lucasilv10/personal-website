---
interface Article {
  slug: string;
  data: {
    title: string;
    date: Date;
    description: string;
    tags: string[];
    readingTime: string;
  };
}

interface Props {
  articles: Article[];
}

const { articles } = Astro.props;
const formatter = new Intl.DateTimeFormat("en", {
  month: "long",
  day: "numeric",
  year: "numeric",
  timeZone: "UTC"
});
---

{
  articles.length > 0 && (
    <div class="space-y-4">
      {articles.map((article, index) => (
        <article class="group relative border border-rule bg-[#fbfaf6]/70 px-5 py-5 shadow-[0_1px_0_rgba(23,23,23,0.06)] transition duration-200 ease-out hover:-translate-y-1 hover:border-ink hover:bg-[#fcfbf7] hover:shadow-[0_10px_26px_rgba(23,23,23,0.07)] sm:grid sm:grid-cols-[120px_1fr] sm:gap-8">
          <div class="mb-4 sm:mb-0">
            <p class="text-[11px] uppercase tracking-[0.14em] text-muted">0{index + 1}</p>
            <div class="mt-3 h-px w-10 bg-rule transition-colors group-hover:bg-ink" aria-hidden="true" />
          </div>
          <div>
            <div class="mb-3 flex flex-wrap items-center justify-between gap-x-4 gap-y-2 text-sm text-muted">
              <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
                <time datetime={article.data.date.toISOString()}>
                  {formatter.format(article.data.date)}
                </time>
                <span aria-hidden="true">/</span>
                <span>{article.data.readingTime}</span>
              </div>
              {article.data.tags[0] && (
                <span class="whitespace-nowrap rounded-md border border-rule/70 bg-paper/50 px-2.5 py-1 text-[11px] uppercase tracking-[0.1em] text-muted shadow-[0_1px_0_rgba(23,23,23,0.03)]">
                  {article.data.tags[0]}
                </span>
              )}
            </div>
            <h2 class="text-xl font-normal leading-snug text-ink">
              <a href={`/writing/${article.slug}`} class="no-underline hover:underline">
                {article.data.title}
              </a>
            </h2>
            {article.data.description && (
              <p class="mt-3 leading-7 text-muted">{article.data.description}</p>
            )}
          </div>
        </article>
      ))}
    </div>
  )
}
