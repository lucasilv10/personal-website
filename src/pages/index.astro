---
import Layout from "../components/Layout.astro";
import ArticleList from "../components/ArticleList.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { projects } from "../data/projects";
import { getCollection } from "astro:content";

const writing = (await getCollection("writing"))
  .sort((a, b) => {
    const aUnpublished = a.data.readingTime === "TBD";
    const bUnpublished = b.data.readingTime === "TBD";

    if (aUnpublished !== bUnpublished) {
      return aUnpublished ? 1 : -1;
    }

    return b.data.date.valueOf() - a.data.date.valueOf();
  })
  .slice(0, 3);
const selectedProjects = projects.slice(0, 3);
const projectNotes = [
  {
    title: "Shipment Risk Reasons",
    image: "/images/projects/shipment-risk-reasons.png",
    secondaryImage: "/images/projects/risk-reasons-planning.png",
    secondaryLabel: "Planning",
    imageFit: "contain",
    experience: "Uber Freight Tracking",
    description:
      "AI-generated delay explanations that help freight teams understand shipment risk, identify likely causes, and act before exceptions become customer issues.",
    tools: ["Figma", "SQL", "LLMs", "Freight Data"]
  },
  {
    title: "Tracking Page AI Summary",
    image: "/images/projects/tracking-page-ai-summary.png",
    secondaryImage: "/images/projects/tracking-page-before.png",
    secondaryLabel: "Before",
    imageFit: "contain",
    experience: "Uber Freight Tracking",
    description:
      "A tracking-page summary experience that turns shipment events, ETA changes, and delay signals into a clearer status narrative for operators.",
    tools: ["Figma", "SQL", "Prompting", "Product Analytics"]
  },
  {
    title: "Job Posting Onboarding",
    image: "/images/projects/job-posting-onboarding.png",
    experience: "Instawork Permanent Hiring",
    description:
      "A guided job-posting flow designed to reduce friction for employers and make permanent hiring setup easier to complete.",
    tools: ["Figma", "Lovable", "HubSpot", "A/B Testing"]
  },
  {
    title: "Hiring Cost & ROI Calculator",
    image: "/images/projects/hiring-cost-calculator.png",
    experience: "Instawork Permanent Hiring",
    description:
      "A gated calculator experience built to help hiring teams estimate costs, see potential savings, and generate qualified product leads.",
    tools: ["Cursor", "React", "HubSpot", "Analytics"]
  }
];
const projectNoteStyles = [
  {
    paper: "bg-[#fcfbf7]",
    tape: "bg-[#e8e1d6]"
  },
  {
    paper: "bg-[#fbfaf6]",
    tape: "bg-[#ded8cf]"
  },
  {
    paper: "bg-[#fdfbf4]",
    tape: "bg-[#e7ddcb]"
  },
  {
    paper: "bg-[#fbfaf6]",
    tape: "bg-[#e5ded2]"
  }
];
---

<Layout
  title="About"
  description="About Luca Silveira: product manager and business student interested in AI, logistics, marketplaces, global markets, and Brazil."
>
  <section class="border-b border-rule pb-8" data-nav-section="about">
    <div class="mb-8 h-px w-full bg-ink" aria-hidden="true" />
    <h1 class="max-w-4xl text-4xl font-normal leading-tight tracking-normal text-ink sm:text-5xl">
      Luca Silveira
    </h1>
    <p class="mt-6 text-lg text-ink">Miami, FL</p>
    <p class="mt-2 text-base text-muted">25.8648° N, 80.1806° W</p>
    <div class="mt-6 h-px w-full bg-ink" aria-hidden="true" />
    <div class="mt-10 grid gap-8 sm:grid-cols-[240px_1fr] sm:items-start lg:gap-12">
      <div class="relative w-56 max-w-full sm:mt-3 sm:w-full">
        <div class="absolute -left-3 -top-3 h-full w-full border border-ink/80" aria-hidden="true" />
        <img
          src="/images/luca-headshot.png"
          alt="Luca Silveira headshot"
          class="relative w-full border border-rule object-cover shadow-[0_12px_26px_rgba(23,23,23,0.08)]"
        />
      </div>
      <div class="max-w-3xl border-t border-rule pt-5 sm:-mt-2 sm:border-t-0 sm:pt-0">
        <p class="leading-8 text-ink">
          Hi, I’m Luca. I’m a senior at the University of Michigan studying business at
          Ross. This summer, I'm working as a product management intern at Uber, where
          I’m building AI features and tracking tools for Freight platforms. Before that,
          I worked on growth at Instawork, a labor marketplace startup, and spent a summer
          in Rio de Janeiro as an analyst at Fuse Capital, a crypto venture fund.
        </p>
        <p class="mt-6 leading-8 text-ink">
          I’m Brazilian-American and grew up in Miami, where I became passionate about
          entrepreneurship, soccer, and the outdoors. In high school, I built a boat
          dealership business and a real estate aerial photography operation. I balanced
          both while competing as a midfielder in the MLS Next and Florida’s Olympic
          Development Program, later joining the club soccer team at Michigan.
        </p>
      </div>
    </div>
  </section>

  <section class="border-b border-rule pb-12 pt-8">
    <div class="mb-1">
      <h2 class="text-2xl font-normal uppercase tracking-[0.12em] text-ink">Experience</h2>
    </div>
    {selectedProjects.map((project) => <ProjectCard {...project} />)}
  </section>

  <section id="projects" class="py-12" data-nav-section="projects">
    <div class="mb-8">
      <h2 class="text-2xl font-normal uppercase tracking-[0.12em] text-ink">Projects</h2>
    </div>
    <div class="space-y-7">
      {
        projectNotes.map((project, index) => {
          const noteStyle = projectNoteStyles[index % projectNoteStyles.length];
          return (
          <article
            class:list={[
              "group relative overflow-hidden border border-rule shadow-[0_1px_0_rgba(23,23,23,0.08),0_18px_38px_rgba(23,23,23,0.08)] transition duration-300 ease-out before:pointer-events-none before:absolute before:inset-0 before:bg-[linear-gradient(135deg,rgba(255,255,255,0.72),rgba(255,255,255,0)_38%)] before:content-[''] hover:-translate-y-1 hover:border-ink hover:shadow-[0_1px_0_rgba(23,23,23,0.12),0_24px_48px_rgba(23,23,23,0.12)]",
              noteStyle.paper
            ]}
          >
            <span
              class:list={[
                "absolute left-8 top-0 z-[2] h-2 w-20 border-x border-b border-rule/70 opacity-85 shadow-[0_4px_10px_rgba(23,23,23,0.06)]",
                noteStyle.tape
              ]}
              aria-hidden="true"
            />
            <div class="relative z-[1] grid gap-0 lg:grid-cols-[minmax(0,1.72fr)_minmax(280px,0.48fr)]">
              <div class="relative min-h-64 overflow-hidden border-b border-rule bg-paper lg:min-h-[390px] lg:border-b-0 lg:border-r">
                {project.secondaryImage ? (
                  <div class="flex h-full min-h-64 flex-col justify-center gap-5 p-5 sm:p-7 lg:min-h-[390px]">
                    <div class="overflow-hidden border border-rule bg-white/80 p-2 shadow-[0_1px_0_rgba(23,23,23,0.06),0_12px_26px_rgba(23,23,23,0.08)] transition duration-300 ease-out group-hover:-translate-y-1">
                      <div class="mb-2 flex items-center gap-3">
                        <span class="text-[10px] uppercase tracking-[0.14em] text-muted">
                          {project.title === "Tracking Page AI Summary" ? "AI Summary Card" : "Risk UI"}
                        </span>
                        <span class="h-px flex-1 bg-rule/70" aria-hidden="true" />
                      </div>
                      <img
                        src={project.image}
                        alt={`${project.title} main preview`}
                        class:list={[
                          project.title === "Tracking Page AI Summary"
                            ? "w-full object-contain object-center"
                            : "mx-auto h-48 w-full object-contain sm:h-52"
                        ]}
                      />
                    </div>
                    <div class="ml-auto w-[66%] border border-rule/60 bg-white/45 p-2 opacity-75 shadow-[0_1px_0_rgba(23,23,23,0.03),0_8px_16px_rgba(23,23,23,0.04)] transition duration-300 ease-out group-hover:translate-y-1 group-hover:opacity-90 sm:w-[58%]">
                      <div class="mb-2 flex items-center gap-3">
                        <span class="text-[10px] uppercase tracking-[0.14em] text-muted">
                          {project.secondaryLabel}
                        </span>
                        <span class="h-px flex-1 bg-rule/60" aria-hidden="true" />
                      </div>
                      <img
                        src={project.secondaryImage}
                        alt={`${project.title} supporting preview`}
                        class:list={[
                          "w-full object-cover object-top",
                          project.title === "Tracking Page AI Summary" ? "aspect-[2.25/1]" : "aspect-[2.8/1]"
                        ]}
                      />
                    </div>
                  </div>
                ) : (
                  <img
                    src={project.image}
                    alt={`${project.title} preview`}
                    class:list={[
                      "h-full w-full transition duration-300 ease-out group-hover:scale-[1.03]",
                      project.imageFit === "contain"
                        ? "object-contain object-center p-6 sm:p-8"
                        : "object-cover object-top"
                    ]}
                  />
                )}
                <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(247,244,238,0)_62%,rgba(247,244,238,0.52))] opacity-0 transition-opacity duration-300 group-hover:opacity-100" aria-hidden="true" />
              </div>
              <div class="relative flex min-h-64 items-center p-5 sm:p-6 lg:min-h-[390px] lg:pl-2 xl:pr-7">
                <div class="relative w-full border border-rule bg-paper/90 p-4 shadow-[0_1px_0_rgba(23,23,23,0.08),0_14px_30px_rgba(23,23,23,0.08)] backdrop-blur-sm lg:-ml-2 xl:ml-0">
                  <div class="mb-8 flex items-center justify-between gap-4">
                    <span class="whitespace-nowrap rounded-md border border-rule bg-[#fbfaf6] px-2 py-1 text-[11px] uppercase tracking-[0.1em] text-muted shadow-[0_1px_0_rgba(23,23,23,0.08),0_6px_18px_rgba(23,23,23,0.04)]">
                      {project.experience}
                    </span>
                    <span class="h-px flex-1 bg-rule" aria-hidden="true" />
                    <span class="text-[11px] uppercase tracking-[0.14em] text-muted">
                      0{index + 1}
                    </span>
                  </div>
                  <h3 class="text-2xl font-normal leading-tight text-ink">{project.title}</h3>
                  <p class="mt-4 text-base leading-7 text-muted">{project.description}</p>
                  <p class="mt-5 border-t border-rule/60 pt-3 text-[11px] leading-5 text-muted/80">
                    <span class="uppercase tracking-[0.14em]">Tools</span>
                    <span class="mx-2 text-rule" aria-hidden="true">/</span>
                    <span>{project.tools.join(" · ")}</span>
                  </p>
                </div>
              </div>
            </div>
          </article>
          );
        })
      }
    </div>
  </section>

  <section id="writing" class="border-t border-rule py-12" data-nav-section="writing">
    <div class="mb-6">
      <h2 class="text-2xl font-normal uppercase tracking-[0.12em] text-ink">Writing</h2>
    </div>
    <ArticleList articles={writing} />
  </section>

  <section class="border-t border-rule py-10">
    <a
      href="/interview"
      class="group block border border-rule bg-[#fbfaf6]/70 px-5 py-6 no-underline shadow-[0_1px_0_rgba(23,23,23,0.06)] transition duration-200 ease-out hover:-translate-y-1 hover:border-ink hover:bg-[#fcfbf7] hover:shadow-[0_12px_28px_rgba(23,23,23,0.08)]"
    >
      <div class="flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <h2 class="text-2xl font-normal uppercase tracking-[0.12em] text-ink">Interview</h2>
          <p class="mt-4 max-w-2xl text-xl leading-8 text-ink">Click to Learn More</p>
        </div>
        <span class="flex items-center gap-3 text-sm uppercase tracking-[0.12em] text-muted transition-colors group-hover:text-ink">
          Open
          <span class="h-px w-12 bg-rule transition-all group-hover:w-16 group-hover:bg-ink" aria-hidden="true" />
        </span>
      </div>
    </a>
  </section>
</Layout>
