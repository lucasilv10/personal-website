---
import Layout from "../components/Layout.astro";
import PageHeader from "../components/PageHeader.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { projects } from "../data/projects";
---

<Layout
  title="Projects"
  description="Selected product, growth, consulting, and research projects by Luca Silveira."
>
  <PageHeader
    eyebrow="Projects"
    title="Selected work across product, GTM, logistics, marketplaces, and investing research."
    description="A concise record of problems I have spent time with and the operating contexts around them."
  />
  <section>
    {projects.map((project) => <ProjectCard {...project} />)}
  </section>
</Layout>
